{
	"name": "clean-nest",
	"version": "0.0.1",
	"description": "",
	"author": "",
	"private": true,
	"license": "UNLICENSED",
	"scripts": {
		"build": "tsc --noEmit && nest build",
		"format": "prettier --write \"src/**/*.ts\"  \"libs/**/*.ts\"",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"lint": "eslint \"{src,apps,libs}/**/*.ts\" --fix",
		"lint:fix": "eslint \"{src,apps,libs}/**/*.ts\" --fix",
		"typecheck": "tsc --noEmit",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"test:e2e": "jest --config ./test/jest-e2e.json",
		"prepare": "husky"
	},
	"dependencies": {
		"@fastify/helmet": "^13.0.2",
		"@fastify/multipart": "^10.0.0",
		"@fastify/static": "^9.1.3",
		"@nestjs-modules/mailer": "^2.3.6",
		"@nestjs/bullmq": "^11.0.4",
		"@nestjs/cache-manager": "^3.1.2",
		"@nestjs/common": "^11.1.24",
		"@nestjs/config": "^4.0.4",
		"@nestjs/core": "^11.1.24",
		"@nestjs/jwt": "^11.0.2",
		"@nestjs/mapped-types": "^2.1.1",
		"@nestjs/passport": "^11.0.5",
		"@nestjs/platform-fastify": "^11.1.24",
		"@nestjs/serve-static": "^5.0.5",
		"@nestjs/swagger": "^11.4.4",
		"@nestjs/terminus": "^11.1.1",
		"@nestjs/throttler": "^6.5.0",
		"@scalar/nestjs-api-reference": "^1.1.19",
		"bcryptjs": "^3.0.3",
		"bullmq": "^5.77.6",
		"cache-manager": "^7.2.8",
		"cache-manager-ioredis-yet": "^2.1.2",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.15.1",
		"crypto-js": "^4.2.0",
		"dayjs": "^1.11.21",
		"drizzle-orm": "^0.45.2",
		"envalid": "^8.1.1",
		"fastify": "^5.8.5",
		"handlebars": "^4.7.9",
		"ioredis": "^5.11.0",
		"nodemailer": "^8.0.10",
		"passport": "^0.7.0",
		"passport-jwt": "^4.0.1",
		"passport-local": "^1.0.0",
		"pg": "^8.21.0",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@nestjs/cli": "^11.0.21",
		"@nestjs/schematics": "^11.1.0",
		"@nestjs/testing": "^11.1.24",
		"@types/bun": "^1.3.14",
		"@types/handlebars": "^4.1.0",
		"@types/jest": "^30.0.0",
		"@types/multer": "^2.1.0",
		"@types/node": "^25.9.1",
		"@types/nodemailer": "^8.0.0",
		"@types/passport-local": "^1.0.38",
		"@types/pg": "^8.20.0",
		"@types/supertest": "^7.2.0",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-prettier": "^5.5.6",
		"eslint-plugin-simple-import-sort": "^13.0.0",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"jest": "^30.4.2",
		"lint-staged": "^17.0.7",
		"prettier": "^3.8.3",
		"prisma": "^7.8.0",
		"source-map-support": "^0.5.21",
		"supertest": "^7.2.2",
		"ts-jest": "^29.4.11",
		"ts-loader": "^9.6.0",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.0"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": ".",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "./coverage",
		"testEnvironment": "node",
		"roots": [
			"<rootDir>/src/",
			"<rootDir>/libs/"
		],
		"moduleNameMapper": {
			"^@common(|/.*)$": "<rootDir>/libs/common/src/$1",
			"^@repositories/repositories(|/.*)$": "<rootDir>/libs/repositories/src/$1",
			"^@utils(|/.*)$": "<rootDir>/libs/utils/src/$1",
			"^config/config(|/.*)$": "<rootDir>/libs/config/src/$1"
		}
	},
	"lint-staged": {
		"*.{ts,js}": [
			"bun run lint",
			"bun run format"
		]
	}
}
